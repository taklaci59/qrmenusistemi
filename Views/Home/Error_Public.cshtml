@{
    ViewData["Title"] = "Hata";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <div class="card p-5 border-danger">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 5rem;"></i>
            </div>
            <h2 class="fw-bold mb-3">Erişim Hatası</h2>
            <p class="fs-5 text-muted mb-4">@ViewBag.Error</p>
            <p class="small text-muted mb-5">Lütfen masanızdaki QR kodu tekrar okutun veya bir görevliden yardım isteyin.</p>
        </div>
    </div>
</div>
