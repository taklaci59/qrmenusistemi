@model IEnumerable<qrmenusistemiuygulama18.Models.Category>
@{
    ViewData["Title"] = "Menü";
}

<div class="row mb-5">
    <div class="col-12 text-center">
        <h1 class="display-4 fw-bold">Damak Tadınıza Göre<span>.</span></h1>
        <p class="text-muted">Kıvançlı Lezzetler kalitesiyle hazırlanan eşsiz lezzetler.</p>
    </div>
</div>

<!-- Kategoriler -->
<div class="category-scroll d-flex overflow-auto pb-3 mb-4 no-scrollbar" style="-ms-overflow-style: none; scrollbar-width: none;">
    @foreach (var category in Model)
    {
        <a href="#cat-@category.Id" class="btn btn-light rounded-pill px-4 py-2 me-2 shadow-sm text-nowrap border-0 @(category == Model.First() ? "bg-warning" : "")">
            @category.Name
        </a>
    }
</div>

@foreach (var category in Model)
{
    <div id="cat-@category.Id" class="mb-5">
        <h3 class="fw-bold mb-4 border-start border-warning border-4 ps-3">@category.Name</h3>
        <div class="row g-4">
            @foreach (var product in category.Products)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 overflow-hidden">
                        <div class="ratio ratio-4x3">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://placehold.co/600x400?text=Nano+Banana" : product.ImageUrl)" class="card-img-top object-fit-cover" alt="@product.Name">
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@product.Name</h5>
                            <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fs-4 fw-bold text-dark">@product.Price.ToString("C2")</span>
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-primary rounded-circle p-2 px-3">
                                        <i class="bi bi-plus-lg fs-5"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .object-fit-cover {
            object-fit: cover;
        }
    </style>
}
