@{
    ViewData["Title"] = "Sipariş Tamamlandı";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <div class="card p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            <h2 class="fw-bold mb-3">Harika!</h2>
            <p class="fs-5 text-muted mb-4">@ViewBag.Message</p>
            <p class="small text-muted mb-5">Hazırlanmaya başlandığında garsonunuz masanıza uğrayacaktır. Afiyet olsun!</p>
            <a asp-controller="Home" asp-action="Menu" asp-route-table="@ViewContext.HttpContext.Request.Form["table"]" class="btn btn-primary px-5">Menüye Dön</a>
        </div>
    </div>
</div>
