@model IEnumerable<qrmenusistemiuygulama18.Models.Order>
@using qrmenusistemiuygulama18.Models.Enums
@{
    ViewData["Title"] = "Aktif Siparişler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0 text-secondary">Canlı Sipariş Takibi</h2>
    <span class="badge bg-danger p-2 px-3">@Model.Count() Aktif</span>
</div>

<div class="row g-4">
    @foreach (var order in Model)
    {
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 border-top border-4 border-warning">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <span class="fw-bold fs-5">Masa #@order.Table?.TableNumber</span>
                    <span class="text-muted small">@order.OrderDate.ToString("HH:mm")</span>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush mb-4">
                        @foreach (var item in order.OrderItems)
                        {
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span><span class="badge bg-light text-dark me-2">@item.Quantity x</span> @item.Product?.Name</span>
                                <span class="text-muted">@((item.UnitPrice * item.Quantity).ToString("C2"))</span>
                            </li>
                        }
                    </ul>
                    <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                        <span class="fw-bold">Toplam:</span>
                        <span class="fs-5 fw-black text-warning">@order.TotalPrice.ToString("C2")</span>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pb-4 pt-0">
                    <div class="d-grid gap-2">
                        @if (order.Status == OrderStatus.New)
                        {
                            <form asp-action="UpdateOrderStatus" method="post">
                                <input type="hidden" name="orderId" value="@order.Id" />
                                <input type="hidden" name="status" value="@OrderStatus.Preparing" />
                                <button type="submit" class="btn btn-primary w-100">Hazırlanıyor Yap</button>
                            </form>
                        }
                        else if (order.Status == OrderStatus.Preparing)
                        {
                            <form asp-action="UpdateOrderStatus" method="post">
                                <input type="hidden" name="orderId" value="@order.Id" />
                                <input type="hidden" name="status" value="@OrderStatus.Served" />
                                <button type="submit" class="btn btn-success w-100 text-white">Servis Edildi</button>
                            </form>
                        }
                        
                        <form asp-action="UpdateOrderStatus" method="post">
                            <input type="hidden" name="orderId" value="@order.Id" />
                            <input type="hidden" name="status" value="@OrderStatus.Cancelled" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100 mt-2">İptal Et</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="bg-white p-5 rounded-4 shadow-sm">
                <i class="bi bi-cup-hot text-muted display-1"></i>
                <p class="mt-3 fs-5">Şu an bekleyen aktif sipariş yok.</p>
            </div>
        </div>
    }
</div>
