@model IEnumerable<qrmenusistemiuygulama18.Models.Product>
@{
    ViewData["Title"] = "Ürün Yönetimi";
}

<div class="card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Ürünler</h3>
        <a asp-action="AddProduct" class="btn btn-primary d-flex align-items-center">
            <i class="bi bi-plus-lg me-2"></i> Yeni Ürün Ekle
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/50" : item.ImageUrl)" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;">
                        </td>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                            <div class="small text-muted text-truncate" style="max-width: 200px;">@item.Description</div>
                        </td>
                        <td><span class="badge bg-secondary">@item.Category?.Name</span></td>
                        <td class="fw-bold">@item.Price.ToString("C2")</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="EditProduct" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmDelete(@item.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <form id="delete-form-@item.Id" asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" style="display:none;"></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Bu ürünü silmek istediğinize emin misiniz?')) {
                document.getElementById('delete-form-' + id).submit();
            }
        }
    </script>
}
