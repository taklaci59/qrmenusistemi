@model IEnumerable<qrmenusistemiuygulama18.Models.Category>
@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<div class="row">
    <div class="col-md-4">
        <div class="card p-4 mb-4">
            <h4 class="fw-bold mb-4">Yeni Kategori</h4>
            <form asp-action="AddCategory" method="post">
                <div class="mb-3">
                    <label class="form-label">Kategori Adı</label>
                    <input type="text" name="name" class="form-control" placeholder="Örn: Kebaplar" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Ekle</button>
            </form>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card p-4">
            <h4 class="fw-bold mb-4">Mevcut Kategoriler</h4>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Kategori Adı</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td class="fw-bold">@item.Name</td>
                                <td class="text-end">
                                    <form asp-action="DeleteCategory" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz? Bağlı ürünler etkilenebilir.')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
