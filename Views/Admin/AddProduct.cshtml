@model qrmenusistemiuygulama18.Models.Product
@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="card p-4 mx-auto" style="max-width: 800px;">
    <h3 class="fw-bold mb-4">Yeni Ürün Ekle</h3>
    <form asp-action="AddProduct" method="post" enctype="multipart/form-data">
        <div class="row g-3">
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="form-label">Ürün Adı</label>
                    <input asp-for="Name" class="form-control" placeholder="Örn: Adana Kebap" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="İçindekiler ve porsiyon bilgisi..."></textarea>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label class="form-label">Görsel Seç</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    <div class="mt-2 text-center">
                        <img id="imgPreview" src="https://placehold.co/400x300?text=Onizleme" class="img-fluid rounded shadow-sm" style="max-height: 200px; display: none;">
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Kategori</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required>
                        <option value="">Kategori Seçiniz</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Fiyat (₺)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                </div>
            </div>

            <div class="col-12 mt-4">
                <hr>
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Products" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-primary px-5">Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = document.getElementById('imgPreview');
                img.src = e.target.result;
                img.style.display = 'block';
            }
            if (input.files && input.files[0]) {
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
